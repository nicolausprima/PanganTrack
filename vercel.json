{
  "version": 2,
  "builds": [
    {
      "src": "PanganTrack/api/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "PanganTrack/api/main.py"
    },
    {
      "src": "/(css|js|assets)/(.*)",
      "dest": "PanganTrack/frontend/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "PanganTrack/frontend/index.html"
    }
  ]
}
